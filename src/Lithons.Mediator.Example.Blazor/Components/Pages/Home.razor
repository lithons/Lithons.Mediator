@page "/"
@using Lithons.Mediator.Example.Blazor.Handlers
@rendermode InteractiveServer
@inject IMediator Mediator

<PageTitle>Counter</PageTitle>

<h1>String Reverser</h1>

<div class="mb-3">
    <label for="inputValue" class="form-label">Input</label>
    <input id="inputValue" class="form-control" @bind="_inputValue" placeholder="Enter text to reverse" />
</div>

<button class="btn btn-primary" @onclick="ReverseString">Reverse</button>

@if (_reversedValue is not null)
{
    <p role="status" class="mt-3">Result: <strong>@_reversedValue</strong></p>
}

@code {
    private string _inputValue = string.Empty;
    private string? _reversedValue;

    private async Task ReverseString()
    {
        _reversedValue = await Mediator.SendAsync(new StringReverseRequest(_inputValue));
    }
}
